# Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord guild (server) ID where the bot operates
DISCORD_GUILD_ID=your_guild_id_here

# Role ID for @Resume-Reviewer (set after role is created in Discord)
RESUME_REVIEWER_ROLE_ID=your_role_id_here

# Channel ID for leaderboard posts
LEADERBOARD_CHANNEL_ID=your_channel_id_here

# Base URL of the NoiceResume site (used for referral links)
NOICERESUME_BASE_URL=https://noiceresume.pages.dev

# Webhook secret shared with the referral-webhook worker
REFERRAL_WEBHOOK_SECRET=change-me-to-a-random-secret

# URL of the referral-webhook Cloudflare Worker
REFERRAL_WEBHOOK_URL=https://referral-webhook.your-worker.workers.dev
